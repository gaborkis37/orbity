# HTTP port the API listens on
PORT=4000

# Comma-separated list of allowed CORS origins (the web app). Used from Task 2.1.
CORS_ORIGINS=http://localhost:3000

# CelesTrak base URL — SERVER-SIDE ONLY. The browser must never call CelesTrak.
CELESTRAK_BASE_URL=https://celestrak.org/NORAD/elements

# Redis (Upstash) connection string — added/used in Task 2.2
REDIS_URL=

# Admin token guarding POST /admin/refresh — added/used in Task 2.2
ADMIN_TOKEN=
