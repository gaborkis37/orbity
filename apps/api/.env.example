# Runtime environment: development | production | test
NODE_ENV=development

# HTTP port the API listens on
PORT=4000

# Comma-separated list of allowed CORS origins (the web app).
CORS_ORIGINS=http://localhost:3000

# CelesTrak base URL — SERVER-SIDE ONLY. The browser must never call CelesTrak.
CELESTRAK_BASE_URL=https://celestrak.org/NORAD/elements

# Ingestion cadence in hours (CelesTrak forbids refreshing more often than every 2 h).
REFRESH_INTERVAL_HOURS=6

# Redis (Upstash) connection string — used from Task 2.2
REDIS_URL=

# Admin token guarding POST /admin/refresh — used from Task 2.2
ADMIN_TOKEN=
